# =============================================================
# Training App — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------------
# Database (shared PostgreSQL instance, one schema per service)
# -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trainingapp
POSTGRES_USER=trainingapp_user
POSTGRES_PASSWORD=changeme_use_a_strong_random_value_in_production

# -------------------------------------------------------------
# Auth Service — JWT
# JWT_SECRET must be a 256-bit (32-byte) random hex string.
# Generate with: openssl rand -hex 32
# COOKIE_SECURE: false for local HTTP dev, true for any HTTPS environment.
# -------------------------------------------------------------
JWT_SECRET=replace_with_256bit_random_hex_string_generated_by_openssl_rand_hex_32
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
COOKIE_SECURE=false

# -------------------------------------------------------------
# Auth Service — Admin seed user
# Created on first startup if the username does not already exist.
# Change these before deploying to any non-local environment.
# -------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@trainingapp.local
ADMIN_PASSWORD=changeme_use_a_strong_random_value_in_production

# -------------------------------------------------------------
# API Gateway — CORS
# Whitelist only the origin(s) your frontend is served from.
# Production example: https://app.yourdomain.com
# -------------------------------------------------------------
ALLOWED_ORIGIN=http://localhost:5173

# -------------------------------------------------------------
# Internal service URLs
# Used by the gateway to route requests and by training-service
# to notify analytics-service on session completion.
# In Docker Compose these resolve via the service name.
# -------------------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:8081
TRAINING_SERVICE_URL=http://training-service:8082
ANALYTICS_SERVICE_URL=http://analytics-service:8083

# -------------------------------------------------------------
# Frontend
# The base URL the React app uses for all API calls.
# In production this is the public URL of your api-gateway.
# -------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
